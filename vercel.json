{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/", "destination": "/india/delhi", "permanent": false },
    { "source": "/india", "destination": "/india/delhi", "permanent": false }
  ]
}
